{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install requirements (.venv)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["-m", "pip", "install", "-r", "${workspaceFolder}/requirements.txt"],
      "windows": {
        "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
        "args": ["-m", "pip", "install", "-r", "${workspaceFolder}\\requirements.txt"]
      },
      "problemMatcher": []
    }
  ]
}
