{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Streamlit: app.py",
      "type": "python",
      "request": "launch",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "module": "streamlit",
      "args": ["run", "app.py"],
      "console": "integratedTerminal",
      "justMyCode": true,
      "preLaunchTask": "Install requirements (.venv)"
    }
  ]
}
